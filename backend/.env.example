# Chain
RPC_URL=https://testnet.hsk.xyz
CHAIN_ID=133
OPERATOR_PRIVATE_KEY=0x...
BLIND_BOX_ADDRESS=0x...

# Optional Vault
# VAULT_ADDRESS=0x...

# Real ZK (commit_open circuit)
# MOCK_PROOF=0
# CIRCUIT_WASM_PATH=.../commit_open.wasm
# CIRCUIT_ZKEY_PATH=.../commit_open_final.zkey

# Postgres（compose 映射端口 5433，不要用 5432 除非你自己改的）
# DATABASE_URL=postgresql://blindbox:blindbox@localhost:5433/blindbox

# 3C: internal/register-box 默认是否上链（脚本里可覆盖）
# REGISTER_ON_CHAIN=1

# ========== 一键登记（可选）==========
# 配合 scripts/register-boxes-from-env.sh 或 scripts/start-all.sh / bootstrap.sh
# 必须用链上未占用的 BASE；链上已占 id 会 AlreadyRegistered 或 mismatch，见 README §2.5
#
# REGISTER_BATCH=1              # 设为 1 时：start-all / bootstrap 在后端就绪后自动跑登记
# REGISTER_BASE_BOX_ID=1        # 新部署合约后从 1 开始；沿用旧合约则换未占用号段
# REGISTER_COUNT=25
# REGISTER_ON_CHAIN=1           # 新合约要可开盒用 1；仅 DB 占坑可 0
